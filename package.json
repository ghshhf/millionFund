{
  "name": "fund-app",
  "private": true,
  "version": "1.9.8",
  "description": "AI百万资产 - 全平台全品种资产管理工具，支持基金/股票/加密货币/可转债实时估值、持仓管理、AI调仓追踪",
  "author": {
    "name": "millionFund",
    "email": "fund@millionFund.app"
  },
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "npm run build",
    "build:android": "node scripts/build-all-platforms.mjs android",
    "build:ios": "node scripts/build-all-platforms.mjs ios",
    "build:desktop": "node scripts/build-all-platforms.mjs desktop",
    "build:all": "node scripts/build-all-platforms.mjs all",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{ts,vue}",
    "lint:fix": "eslint src/**/*.{ts,vue} --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "update-funds": "node scripts/fetch-fund-list.mjs",
    "cap:init": "npx cap init",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npm run build && npx cap copy",
    "cap:sync:android": "npm run build && npx cap copy android && npx cap sync android",
    "cap:sync:ios": "npm run build && npx cap copy ios && npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.5",
    "@capacitor/app": "^7.1.1",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.6.6",
    "chart.js": "^4.5.1",
    "lightweight-charts": "^5.1.0",
    "pinia": "^3.0.0",
    "tesseract.js": "^7.0.0",
    "vant": "^4.9.0",
    "vue": "^3.5.24",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.5.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@pinia/testing": "^0.1.6",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.16",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vant/auto-import-resolver": "^1.2.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.8.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^15.11.7",
    "playwright": "^1.61.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^19.0.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^7.2.4",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.1.4"
  },
  "build": {
    "appId": "com.fundapp.realtime",
    "productName": "AI百万资产",
    "copyright": "MIT License",
    "directories": {
      "output": "release/desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI百万实盘"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Finance"
    }
  }
}
