<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许 HTTP 明文流量（Android 9+ 默认禁止） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- 调试时允许 Charles/Fiddler 等代理抓包 -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
